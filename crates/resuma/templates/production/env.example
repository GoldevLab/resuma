RESUMA_ENV=production
RESUMA_ADDR=0.0.0.0:8080
RESUMA_TRUST_PROXY=1
RESUMA_DATA_DIR=/data/resuma
# Required in production — generate: openssl rand -hex 32
RESUMA_EXEC_API_KEY=CHANGE_ME
# Ops dashboard session cookie value — generate: openssl rand -hex 32
# Browser cookie: resuma_session=<this value>
RESUMA_OPS_SESSION=CHANGE_ME
# Optional AI proxy
# RESUMA_AI_API_KEY=
# RESUMA_AI_BASE_URL=https://api.openai.com/v1
# Scheduler tick interval (seconds)
RESUMA_SCHEDULER_TICK_SECS=30
# Webhooks + metrics
# RESUMA_WEBHOOK_URLS=https://hooks.example.com/resuma
# RESUMA_WEBHOOK_SECRET=
# RESUMA_METRICS_PUBLIC=0
