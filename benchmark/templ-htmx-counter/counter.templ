package main

import "fmt"

templ CounterPage(n int) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<title>Templ + HTMX Counter</title>
			<script src="/static/htmx.min.js"></script>
		</head>
		<body>
			<main>
				<h1>Templ + HTMX Counter</h1>
				@CountFragment(n)
				<button hx-post="/increment" hx-target="#count" hx-swap="outerHTML">+</button>
			</main>
		</body>
	</html>
}

templ CountFragment(n int) {
	<p id="count">Current count: { fmt.Sprint(n) }</p>
}
